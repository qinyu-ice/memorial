<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.qinyu.mapper.PlaceMapper">

    <insert id="insertBatch">
        insert into permission_user (perm_id, user_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.permId}, #{item.userId})
        </foreach>
    </insert>

    <delete id="deleteBatch">
        delete from permission_user
        where (perm_id,user_id) in
        <foreach collection="list" item="item" separator=",">
            (#{item.permId},#{item.userId})
        </foreach>
    </delete>

    <select id="existBatch">
        select perm_id, user_id
        from permission_user
        where (perm_id,user_id) in
        <foreach collection="list" item="item" separator=",">
            (#{item.permId},#{item.userId})
        </foreach>
    </select>

</mapper>